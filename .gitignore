# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Large region .pmtiles bundles — host these out-of-band (S3/R2/GitHub release)
# and let the in-app region downloader pull them at runtime.
assets/map/*.pmtiles
*.pmtiles

# Local Codemagic secrets (env-var groups live in Codemagic itself).
.codemagic.local.env

# Internal conversation transcript — contains session notes + secrets that
# must not be published to the public repo.
CONVERSATION_TRANSCRIPT.md
.claude/

# iOS code-signing artifacts (managed by Codemagic / Xcode).
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Runner.xcworkspace/xcuserdata/
ios/Runner.xcodeproj/xcuserdata/
ios/Runner.xcodeproj/project.xcworkspace/xcuserdata/
